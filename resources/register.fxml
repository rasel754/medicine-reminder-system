<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<StackPane stylesheets="@styles.css" prefWidth="800" prefHeight="600" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.RegisterController">
   <children>
      <VBox alignment="CENTER" spacing="15.0" styleClass="card" maxWidth="380.0" maxHeight="520.0">
         <padding>
            <Insets bottom="40.0" left="30.0" right="30.0" top="40.0" />
         </padding>
         <children>
            <Label text="💊 PillSync" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #6366f1;" />
            <Label text="Create a new account" styleClass="text-secondary" style="-fx-font-size: 14px;" />
            
            <VBox alignment="CENTER_LEFT" spacing="5.0">
               <children>
                  <Label text="Username" styleClass="text-secondary" style="-fx-font-weight: bold; -fx-font-size: 12px;" />
                  <TextField fx:id="usernameField" promptText="Choose a username" maxWidth="Infinity" />
               </children>
               <VBox.margin>
                  <Insets top="15.0" />
               </VBox.margin>
            </VBox>
            
            <VBox alignment="CENTER_LEFT" spacing="5.0">
               <children>
                  <Label text="Password" styleClass="text-secondary" style="-fx-font-weight: bold; -fx-font-size: 12px;" />
                  <PasswordField fx:id="passwordField" promptText="Choose a password" maxWidth="Infinity" />
               </children>
            </VBox>
            
            <VBox alignment="CENTER_LEFT" spacing="5.0">
               <children>
                  <Label text="Role" styleClass="text-secondary" style="-fx-font-weight: bold; -fx-font-size: 12px;" />
                  <ComboBox fx:id="roleComboBox" promptText="Select role" maxWidth="Infinity" />
               </children>
            </VBox>
            
            <Label fx:id="statusLabel" wrapText="true" style="-fx-text-fill: #ef4444; -fx-font-size: 12px; -fx-font-weight: bold;" />
            
            <Button fx:id="registerButton" text="Register" onAction="#handleRegister" maxWidth="Infinity" style="-fx-font-size: 14px;" />
            
            <Hyperlink text="Already have an account? Sign In" onAction="#handleShowLogin" style="-fx-text-fill: #6366f1; -fx-underline: true; -fx-font-size: 13px;" />
         </children>
      </VBox>
   </children>
</StackPane>
