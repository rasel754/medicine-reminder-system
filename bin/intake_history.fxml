<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label text="Medication Intake History" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #6366f1;" />
      
      <TableView id="intakeHistoryTable" VBox.vgrow="ALWAYS" prefHeight="450.0">
        <columns>
          <TableColumn id="colHistoryName" text="Medicine Name" prefWidth="250.0" />
          <TableColumn id="colHistoryDosage" text="Dosage" prefWidth="150.0" />
          <TableColumn id="colHistoryStatus" text="Status" prefWidth="150.0" />
          <TableColumn id="colHistoryDate" text="Date" prefWidth="180.0" />
        </columns>
      </TableView>
   </children>
</VBox>
