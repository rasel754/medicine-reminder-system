<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox spacing="30.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.AdminStockController">
   <children>
      <!-- Stock Table List -->
      <VBox spacing="15.0" HBox.hgrow="ALWAYS">
         <children>
            <Label text="Pharmacy Inventory levels" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
            <TableView fx:id="stockTable" VBox.vgrow="ALWAYS" prefHeight="450.0">
               <columns>
                  <TableColumn fx:id="colMedicineName" text="Medicine Name" prefWidth="300.0" />
                  <TableColumn fx:id="colQuantity" text="In Stock (Quantity)" prefWidth="180.0" />
               </columns>
            </TableView>
         </children>
      </VBox>
      
      <!-- Replenishment Form -->
      <VBox spacing="15.0" prefWidth="320.0">
         <children>
            <Label text="Replenish / Update Stock" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #10b981;" />
            
            <VBox spacing="15.0" styleClass="card">
               <children>
                  <!-- Medicine Name -->
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Medicine Name" styleClass="text-secondary" style="-fx-font-weight: bold;" />
                        <TextField fx:id="stockNameField" promptText="e.g., Aspirin 81mg" />
                     </children>
                  </VBox>
                  
                  <!-- Quantity -->
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Add / Set Quantity" styleClass="text-secondary" style="-fx-font-weight: bold;" />
                        <TextField fx:id="stockQuantityField" promptText="e.g., 50" />
                     </children>
                  </VBox>
                  
                  <Label fx:id="stockFeedbackLabel" wrapText="true" style="-fx-font-size: 12px; -fx-font-weight: bold;" />
                  
                  <Button text="Update Stock" onAction="#handleUpdateStock" maxWidth="Infinity" style="-fx-background-color: #10b981;" />
                  <Button text="Delete Selected" onAction="#handleDeleteStock" maxWidth="Infinity" styleClass="button-danger" />
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</HBox>
