<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.MedicineController">
   <children>
      <Label text="Registered Medications" style="-fx-font-size: 26px; -fx-font-weight: bold;" />
      
      <TableView fx:id="medicineTable" VBox.vgrow="ALWAYS" prefHeight="420.0">
        <columns>
          <TableColumn fx:id="colName" text="Name" prefWidth="250.0" />
          <TableColumn fx:id="colDosage" text="Dosage" prefWidth="150.0" />
          <TableColumn fx:id="colTime" text="Time" prefWidth="120.0" />
          <TableColumn fx:id="colExpiry" text="Expiry Date" prefWidth="180.0" />
        </columns>
      </TableView>
      
      <HBox spacing="15.0" alignment="CENTER_RIGHT">
         <children>
            <Button text="Update Selection" onAction="#handleUpdateSelection" styleClass="button-secondary" />
            <Button text="Delete Selection" onAction="#handleDeleteSelection" styleClass="button-danger" />
         </children>
      </HBox>
   </children>
</VBox>
